{
  "name": "poly-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "External autonomous bot runner for the Poly exchange canonical HTTP/SSE API.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "sim:seed": "tsx src/runner/simMarketSeeder.ts",
    "sim:all": "tsx src/runner/simOrchestrator.ts",
    "sim:close": "tsx src/runner/simMarketCloser.ts",
    "sim:resolve": "tsx src/runner/simMarketResolver.ts",
    "sim:health": "tsx src/runner/simHealthChecker.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bots:reset": "tsx scripts/botsReset.ts",
    "bots:restart-clean": "tsx scripts/botsReset.ts --restart"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
