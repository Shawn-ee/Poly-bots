{
  "name": "poly-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "External autonomous bot runner for the Poly exchange canonical HTTP/SSE API.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
